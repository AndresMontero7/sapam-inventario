<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="10" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sapam.inventario.javafx.controller.MainController">
    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;" text="Inventario SAPAM" />
        <Region HBox.hgrow="ALWAYS" />
        <TextField fx:id="txtBuscar" promptText="Buscar por código" style="-fx-pref-height: 32px; -fx-background-radius: 8;" />
        <Button onAction="#buscarProducto" style="-fx-background-color: #4A90E2; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="Buscar" />
        <Button onAction="#abrirNuevoProducto" style="-fx-background-color: #4A90E2; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="+ Nuevo" />
        <Button onAction="#generarReporte" style="-fx-background-color: #28A745; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="Reporte Mensual" />
        <Button onAction="#cerrarSesion" style="-fx-background-color: #E3F2FD; -fx-text-fill: #2C3E50; -fx-font-weight: bold; -fx-background-radius: 8;" text="Cerrar Sesión" />
    </HBox>

    <TableView fx:id="tablaProductos" style="-fx-background-radius: 10; -fx-border-color: #E3F2FD; -fx-border-radius: 10;">
        <columns>
            <TableColumn fx:id="colCodigo" prefWidth="120" text="Código" />
            <TableColumn fx:id="colNombre" prefWidth="200" text="Nombre" />
            <TableColumn fx:id="colCategoria" prefWidth="120" text="Categoría" />
            <TableColumn fx:id="colStock" prefWidth="100" text="Stock" />
            <TableColumn fx:id="colMinimo" prefWidth="100" text="Mínimo" />
            <TableColumn fx:id="colAcciones" prefWidth="180" text="Acciones" />
        </columns>
        <VBox.margin>
            <Insets top="10" />
        </VBox.margin>
    </TableView>

    <Label style="-fx-text-fill: #6c757d;" text="* Los productos en rojo tienen stock bajo" />
</VBox>