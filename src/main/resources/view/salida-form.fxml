<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 15;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sapam.inventario.javafx.controller.SalidaFormController">
    <padding>
        <Insets bottom="30" left="30" right="30" top="30" />
    </padding>

    <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;" text="Dar Salida de Producto" />

    <Label text="Producto:" />
    <Label fx:id="lblProducto" style="-fx-font-weight: bold;" />

    <Label text="Stock actual:" />
    <Label fx:id="lblStock" />

    <TextField fx:id="txtCantidad" promptText="Cantidad a retirar" />

    <TextField fx:id="txtRecibio" promptText="Recibió (nombre)" />

    <HBox alignment="CENTER" spacing="10">
        <Button onAction="#guardarSalida" style="-fx-background-color: #4A90E2; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 100px;" text="Guardar" />
        <Button onAction="#cancelar" style="-fx-background-color: #E3F2FD; -fx-text-fill: #2C3E50; -fx-font-weight: bold; -fx-pref-width: 100px;" text="Cancelar" />
    </HBox>
</VBox>