<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(74,144,226,0.2), 20, 0, 0, 10);" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sapam.inventario.javafx.controller.ProductoFormController">
    <padding>
        <Insets bottom="30" left="30" right="30" top="30" />
    </padding>

    <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;" text="Nuevo Producto" />

    <TextField fx:id="txtCodigo" promptText="Código de barras" style="-fx-pref-height: 40px; -fx-background-radius: 8; -fx-border-color: #E3F2FD; -fx-border-radius: 8;" />

    <TextField fx:id="txtNombre" promptText="Nombre del producto" style="-fx-pref-height: 40px; -fx-background-radius: 8; -fx-border-color: #E3F2FD; -fx-border-radius: 8;" />

    <TextField fx:id="txtDescripcion" promptText="Descripción" style="-fx-pref-height: 40px; -fx-background-radius: 8; -fx-border-color: #E3F2FD; -fx-border-radius: 8;" />

    <TextField fx:id="txtCategoria" promptText="Categoría" style="-fx-pref-height: 40px; -fx-background-radius: 8; -fx-border-color: #E3F2FD; -fx-border-radius: 8;" />

    <HBox spacing="10">
        <TextField fx:id="txtStock" promptText="Stock actual" style="-fx-pref-height: 40px; -fx-background-radius: 8; -fx-border-color: #E3F2FD; -fx-border-radius: 8;" HBox.hgrow="ALWAYS" />
        <TextField fx:id="txtMinimo" promptText="Stock mínimo" style="-fx-pref-height: 40px; -fx-background-radius: 8; -fx-border-color: #E3F2FD; -fx-border-radius: 8;" HBox.hgrow="ALWAYS" />
    </HBox>

    <HBox alignment="CENTER" spacing="10">
        <Button onAction="#guardarProducto" style="-fx-background-color: #4A90E2; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 120px; -fx-pref-height: 40px; -fx-background-radius: 8; -fx-cursor: hand;" text="Guardar" />
        <Button onAction="#cancelar" style="-fx-background-color: #E3F2FD; -fx-text-fill: #2C3E50; -fx-font-weight: bold; -fx-pref-width: 120px; -fx-pref-height: 40px; -fx-background-radius: 8; -fx-cursor: hand;" text="Cancelar" />
    </HBox>
</VBox>